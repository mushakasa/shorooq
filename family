<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>شروق | الصفحة الرومانسية</title>

  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      font-family: "Tahoma", sans-serif;
    }

    body {
      min-height: 100vh;
      background:
        radial-gradient(circle at top right, rgba(255, 192, 203, 0.16), transparent 25%),
        radial-gradient(circle at bottom left, rgba(255, 105, 180, 0.10), transparent 25%),
        linear-gradient(135deg, #160711, #2b0d1f, #4b1532, #190811);
      color: #fff;
      overflow-x: hidden;
      position: relative;
    }

    .stars,
    .hearts {
      position: fixed;
      inset: 0;
      pointer-events: none;
      z-index: 0;
      overflow: hidden;
    }

    .star {
      position: absolute;
      width: 3px;
      height: 3px;
      background: rgba(255,255,255,0.85);
      border-radius: 50%;
      animation: twinkle 3s infinite ease-in-out;
    }

    .floating-heart {
      position: absolute;
      bottom: -30px;
      color: rgba(255, 210, 225, 0.8);
      font-size: 18px;
      animation: floatUp linear forwards;
      user-select: none;
    }

    .main-wrap {
      position: relative;
      z-index: 2;
      min-height: 100vh;
      display: flex;
      justify-content: center;
      align-items: center;
      padding: 35px 18px;
    }

    .card {
      width: 100%;
      max-width: 980px;
      border-radius: 30px;
      padding: 35px 24px;
      background: rgba(255, 255, 255, 0.10);
      border: 1px solid rgba(255,255,255,0.16);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      box-shadow: 0 15px 55px rgba(0,0,0,0.38);
      overflow: hidden;
      position: relative;
    }

    .card::before {
      content: "";
      position: absolute;
      inset: 0;
      background: linear-gradient(135deg, rgba(255,255,255,0.08), transparent 35%, rgba(255,192,203,0.04));
      pointer-events: none;
    }

    .hero {
      text-align: center;
      margin-bottom: 28px;
      position: relative;
      z-index: 2;
    }

    .hero .small {
      color: #ffdbe8;
      opacity: 0.9;
      margin-bottom: 10px;
      font-size: 1rem;
      letter-spacing: 1px;
    }

    .hero h1 {
      font-size: 3rem;
      color: #ffd6e8;
      text-shadow: 0 0 18px rgba(255, 182, 193, 0.25);
      margin-bottom: 10px;
    }

    .hero p {
      max-width: 700px;
      margin: auto;
      line-height: 2;
      color: #fff4f8;
      font-size: 1.1rem;
    }

    .music-box {
      margin: 24px auto 30px;
      display: flex;
      justify-content: center;
      gap: 12px;
      flex-wrap: wrap;
      position: relative;
      z-index: 2;
    }

    .music-btn {
      border: none;
      border-radius: 999px;
      padding: 14px 22px;
      cursor: pointer;
      color: white;
      font-size: 1rem;
      transition: 0.3s ease;
      background: linear-gradient(135deg, #ff5f91, #ff8fb2);
      box-shadow: 0 10px 25px rgba(255, 95, 145, 0.28);
    }

    .music-btn:hover {
      transform: translateY(-2px) scale(1.03);
    }

    .section-title {
      font-size: 1.6rem;
      color: #ffd6e5;
      margin-bottom: 18px;
      text-align: center;
      position: relative;
      z-index: 2;
    }

    .love-message {
      position: relative;
      z-index: 2;
      background: rgba(255,255,255,0.07);
      border: 1px solid rgba(255,255,255,0.09);
      border-radius: 22px;
      padding: 24px;
      line-height: 2.2;
      color: #fff;
      font-size: 1.08rem;
      text-align: center;
      margin-bottom: 26px;
      box-shadow: inset 0 0 25px rgba(255,255,255,0.04);
    }

    .timeline {
      position: relative;
      z-index: 2;
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 18px;
      margin-bottom: 28px;
    }

    .memory-card {
      background: rgba(255,255,255,0.09);
      border: 1px solid rgba(255,255,255,0.12);
      border-radius: 24px;
      padding: 22px;
      transition: 0.35s ease;
      position: relative;
      overflow: hidden;
    }

    .memory-card:hover {
      transform: translateY(-5px);
      box-shadow: 0 12px 30px rgba(0,0,0,0.18);
    }

    .memory-card::after {
      content: "&#10084;";
      position: absolute;
      left: 18px;
      bottom: 12px;
      font-size: 20px;
      opacity: 0.14;
    }

    .memory-label {
      font-size: 1rem;
      color: #ffc9dc;
      margin-bottom: 10px;
    }

    .memory-date {
      font-size: 1.35rem;
      font-weight: bold;
      color: #ffffff;
      margin-bottom: 10px;
    }

    .memory-desc {
      font-size: 0.98rem;
      line-height: 1.8;
      color: #fff0f5;
      opacity: 0.95;
    }

    .surprise-box {
      position: relative;
      z-index: 2;
      text-align: center;
      margin-top: 10px;
    }

    .surprise-btn {
      border: none;
      border-radius: 999px;
      padding: 14px 26px;
      cursor: pointer;
      background: linear-gradient(135deg, #ff4d7e, #ff9ab7);
      color: white;
      font-size: 1rem;
      transition: 0.3s ease;
      box-shadow: 0 8px 24px rgba(255, 77, 126, 0.30);
    }

    .surprise-btn:hover {
      transform: scale(1.05);
    }

    .surprise-text {
      margin-top: 18px;
      min-height: 44px;
      font-size: 1.1rem;
      color: #ffe6ef;
      opacity: 0;
      transform: translateY(10px);
      transition: 0.5s ease;
    }

    .surprise-text.show {
      opacity: 1;
      transform: translateY(0);
    }

    .footer-note {
      position: relative;
      z-index: 2;
      text-align: center;
      margin-top: 26px;
      color: #ffd9e8;
      opacity: 0.95;
      line-height: 2;
      font-size: 1rem;
    }

    .glow {
      position: absolute;
      width: 260px;
      height: 260px;
      border-radius: 50%;
      filter: blur(70px);
      background: rgba(255, 182, 193, 0.14);
      z-index: 1;
      animation: pulse 6s infinite ease-in-out;
    }

